# ローカル開発用の環境変数サンプル
# このファイルを `.env.local` にコピーしてから make backend で読み込まれる

# Firestore Emulator に向ける（このホストが指定されていれば SDK は自動でEmulatorに接続する）
FIRESTORE_EMULATOR_HOST=127.0.0.1:8085

# Emulator はプロジェクトIDを区別しないので任意の文字列でOK
GCP_PROJECT_ID=boiled-app-local

# Goサーバーのポート
PORT=8080

# Geminiは未使用でOK（AIチャットを試したい場合のみ設定）
GEMINI_API_KEY=
